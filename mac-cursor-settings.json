{
    "window.commandCenter": true,
    "extensions.experimental.affinity": {
        "vscodevim.vim": 1
    },
    "workbench.editor.enablePreview": false,
    "workbench.startupEditor": "none",
    "workbench.list.smoothScrolling": true,
    "window.zoomLevel": 1,
    "files.autoSave": "afterDelay",
    "editor.smoothScrolling": true,
    "editor.cursorBlinking": "solid",
    "editor.cursorSmoothCaretAnimation": "on",
    "editor.minimap.enabled": false,
    "editor.insertSpaces": true,
    "vim.mouseSelectionGoesIntoVisualMode": false,
    "vim.autoSwitchInputMethod.enable": true,
    "vim.autoSwitchInputMethod.defaultIM": "com.apple.keylayout.ABC",
    "vim.autoSwitchInputMethod.obtainIMCmd": "/opt/homebrew/bin/im-select",
    "vim.autoSwitchInputMethod.switchIMCmd": "/opt/homebrew/bin/im-select {im}",
    "vim.sneak": false,
    "vim.easymotion": true,
    "vim.incsearch": true,
    "vim.useSystemClipboard": true,
    "vim.useCtrlKeys": true,
    "vim.hlsearch": true,
    "vim.visualstar": true,
    "vim.autoindent": true,
    "vim.ignorecase": true,
    "vim.smartcase": true,
    "vim.surround": true,
    "vim.highlightedyank.enable": true,
    "vim.highlightedyank.duration": 500,
    "vim.highlightedyank.color": "rgba(250, 240, 240, 0.9)",
    "vim.leader": "<space>",
    "vim.normalModeKeyBindingsNonRecursive": [
        {
            "before": [
                "<leader>",
                "r"
            ],
            "commands": [
                "workbench.action.quickOpenRecent"
            ]
        },
        {
            "before": [
                "<leader>",
                "e"
            ],
            "commands": [
                "workbench.files.action.showActiveFileInExplorer"
            ]
        },
        {
            "before": [
                "<leader>",
                "v"
            ],
            "commands": [
                "workbench.action.toggleSidebarVisibility"
            ]
        },
        {
            "before": [
                "<leader>",
                "s"
            ],
            "commands": [
                "workbench.action.gotoSymbol"
            ]
        },
        {
            "before": [
                "<leader>",
                "c"
            ],
            "commands": [
                "workbench.view.scm"
            ]
        },
        {
            "before": [
                "$"
            ],
            "after": [
                "g",
                "_"
            ]
        },
        {
            "before": [
                "g",
                "_"
            ],
            "after": [
                "$"
            ]
        },
        {
            "before": [
                "g",
                "p"
            ],
            "commands": [
                "workbench.action.togglePanel"
            ],
            "when": "editorHasReferenceProvider && editorTextFocus && !inReferenceSearchEditor && !isInEmbeddedEditor"
        },
        {
            "before": [
                ",",
                "z"
            ],
            "commands": [
                "workbench.action.toggleZenMode"
            ],
            "when": "!isAuxiliaryWindowFocusedContext"
        },
        {
            "before": [
                "=",
                "="
            ],
            "commands": [
                "editor.action.formatDocument"
            ],
            "when": "editorHasDocumentFormattingProvider && editorTextFocus && !editorReadonly && !inCompositeEditor"
        },
        {
            "before": [
                "-",
                "-"
            ],
            "commands": [
                "editor.action.organizeImports"
            ],
            "when": "textInputFocus && !editorReadonly && supportedCodeAction =~ /(\\s|^)source\\.organizeImports\\b/"
        },
        {
            "before": [
                ",",
                "<Enter>"
            ],
            "commands": [
                ":nohl"
            ]
        },
        {
            "before": [
                "Q"
            ],
            "after": [
                "g",
                "q"
            ]
        },
        {
            "before": [
                "<BS>",
                "<BS>"
            ],
            "commands": [
                ":nohl"
            ]
        },
        {
            "before": [
                "z",
                "c"
            ],
            "commands": [
                "editor.fold"
            ]
        },
        {
            "before": [
                "z",
                "o"
            ],
            "commands": [
                "editor.unfold"
            ]
        },
        {
            "before": [
                "z",
                "C"
            ],
            "commands": [
                "editor.foldAll"
            ]
        },
        {
            "before": [
                "z",
                "O"
            ],
            "commands": [
                "editor.unfoldAll"
            ]
        },
        {
            "before": [
                "H"
            ],
            "after": [
                "^"
            ]
        },
        {
            "before": [
                "L"
            ],
            "after": [
                "$"
            ]
        },
        {
            "before": [
                "<C-j>"
            ],
            "after": [
                "j",
                "j",
                "j"
            ]
        },
        {
            "before": [
                "<C-k>"
            ],
            "after": [
                "k",
                "k",
                "k"
            ]
        },
        {
            "before": [
                "<C-d>"
            ],
            "after": [
                "<C-e>",
                "<C-e>",
                "<C-e>"
            ]
        },
        {
            "before": [
                "<C-u>"
            ],
            "after": [
                "<C-y>",
                "<C-y>",
                "<C-y>"
            ]
        },
        {
            "before": [
                "[",
                "s"
            ],
            "commands": [
                "editor.action.marker.prevInFiles"
            ],
            "when": "editorTextFocus || !inputFocus"
        },
        {
            "before": [
                "]",
                "s"
            ],
            "commands": [
                "editor.action.marker.nextInFiles"
            ],
            "when": "editorTextFocus || !inputFocus"
        },
        {
            "before": [
                "f"
            ],
            "after": [
                "<leader>",
                "<leader>",
                "f"
            ]
        },
        {
            "before": [
                "F"
            ],
            "after": [
                "<leader>",
                "<leader>",
                "F"
            ]
        },
        {
            "before": [
                "t"
            ],
            "after": [
                "<leader>",
                "<leader>",
                "t"
            ]
        },
        {
            "before": [
                "T"
            ],
            "after": [
                "<leader>",
                "<leader>",
                "T"
            ]
        },
        {
            "before": [
                "w"
            ],
            "after": [
                "<leader>",
                "<leader>",
                "w"
            ]
        },
        {
            "before": [
                "b"
            ],
            "after": [
                "<leader>",
                "<leader>",
                "b"
            ]
        },
        {
            "before": [
                "g",
                "j"
            ],
            "after": [
                "<leader>",
                "<leader>",
                "j"
            ]
        },
        {
            "before": [
                "g",
                "k"
            ],
            "after": [
                "<leader>",
                "<leader>",
                "k"
            ]
        },
        {
            "before": [
                "g",
                "w"
            ],
            "after": [
                "<leader>",
                "<leader>",
                "w"
            ]
        },
        {
            "before": [
                "g",
                "b"
            ],
            "after": [
                "<leader>",
                "<leader>",
                "b"
            ]
        },
        {
            "before": [
                "e"
            ],
            "after": [
                "<leader>",
                "<leader>",
                "e"
            ]
        },
        {
            "before": [
                "g",
                "a"
            ],
            "commands": [
                "editor.action.quickFix"
            ],
            "when": "editorHasCodeActionsProvider && textInputFocus && !editorReadonly"
        },
        {
            "before": [
                "g",
                "A"
            ],
            "commands": [
                "editor.action.autoFix"
            ],
            "when": "textInputFocus && !editorReadonly && supportedCodeAction =~ /(\\s|^)quickfix\\b/"
        },
        {
            "before": [
                "g",
                "d"
            ],
            "commands": [
                "editor.action.goToDeclaration"
            ],
            "when": "editorHasDefinitionProvider && editorTextFocus && !isInEmbeddedEditor"
        },
        {
            "before": [
                "g",
                "D"
            ],
            "commands": [
                "editor.action.goToTypeDefinition"
            ],
            "when": "editorHasReferenceProvider && editorTextFocus && !inReferenceSearchEditor && !isInEmbeddedEditor"
        },
        {
            "before": [
                "g",
                "i"
            ],
            "commands": [
                "editor.action.goToImplementation"
            ],
            "when": "editorHasImplementationProvider && editorTextFocus && !isInEmbeddedEditor"
        },
        {
            "before": [
                "g",
                "r"
            ],
            "commands": [
                "editor.action.goToReferences"
            ],
            "when": "editorHasReferenceProvider && editorTextFocus && !inReferenceSearchEditor && !isInEmbeddedEditor"
        },
        {
            "before": [
                "g",
                "u"
            ],
            "commands": [
                "java.action.navigateToSuperImplementation"
            ],
            "when": "editorHasImplementationProvider && editorTextFocus && !isInEmbeddedEditor"
        },
        {
            "before": [
                "g",
                "h"
            ],
            "commands": [
                "editor.action.showHover"
            ],
            "when": "editorTextFocus"
        },
        {
            "before": [
                "g",
                "H"
            ],
            "commands": [
                "editor.action.quickFix"
            ],
            "when": "editorHasCodeActionsProvider && textInputFocus && !editorReadonly"
        },
        {
            "before": [
                "<leader>",
                "a",
                "p"
            ],
            "commands": [
                "inlineChat.start"
            ],
            "when": "editorFocus && inlineChatHasProvider && inlineChatPossible && !editorReadonly"
        },
        {
            "before": [
                "<leader>",
                "a",
                "m"
            ],
            "commands": [
                "github.copilot.terminal.generateCommitMessage",
                "workbench.action.terminal.focus"
            ],
            "when": "editorTextFocus"
        },
        {
            "before": [
                "<leader>",
                "n"
            ],
            "commands": [
                "editor.action.rename"
            ],
            "when": "editorTextFocus"
        },
        {
            "before": [
                "<leader>",
                "t",
                "c"
            ],
            "commands": [
                "workbench.action.terminal.toggleTerminal"
            ],
            "when": "terminal.active"
        },
        {
            "before": [
                "<C-p>"
            ],
            "commands": [
                "workbench.action.quickOpen"
            ],
            "when": "editorTextFocus || !inputFocus"
        },
        {
            "before": [
                "s",
                "f"
            ],
            "commands": [
                "workbench.action.showEditorsInActiveGroup"
            ],
            "when": "editorTextFocus || !inputFocus"
        },
        {
            "before": [
                "<C-f>"
            ],
            "commands": [
                "workbench.action.quickTextSearch"
            ]
        },
        {
            "before": [
                "<C-i>"
            ],
            "commands": [
                "workbench.action.navigateForward"
            ]
        },
        {
            "before": [
                "<C-o>"
            ],
            "commands": [
                "workbench.action.navigateBack"
            ]
        },
        {
            "before": [
                "<C-w>"
            ],
            "commands": [
                "workbench.action.closeActiveEditor"
            ]
        },
        {
            "before": [
                "<C-h>"
            ],
            "commands": [
                "workbench.action.previousEditorInGroup"
            ]
        },
        {
            "before": [
                "<C-l>"
            ],
            "commands": [
                "workbench.action.nextEditorInGroup"
            ]
        },
        {
            "before": [
                "<C-m>"
            ],
            "commands": [
                "workbench.action.togglePanel"
            ]
        },
        {
            "before": [
                "<leader>",
                "b",
                "o"
            ],
            "commands": [
                "workbench.action.closeOtherEditors"
            ]
        },
        {
            "before": [
                "<leader>",
                "b",
                "l"
            ],
            "commands": [
                "workbench.action.closeEditorsToTheLeft"
            ]
        },
        {
            "before": [
                "<leader>",
                "b",
                "r"
            ],
            "commands": [
                "workbench.action.closeEditorsToTheRight"
            ]
        },
        {
            "before": [
                "s",
                "v"
            ],
            "commands": [
                "workbench.action.splitEditor"
            ]
        },
        {
            "before": [
                "s",
                "h"
            ],
            "commands": [
                "workbench.action.splitEditorDown"
            ]
        },
        {
            "before": [
                "s",
                "c"
            ],
            "commands": [
                "workbench.action.closeActiveEditor"
            ]
        },
        {
            "before": [
                "s",
                "o"
            ],
            "commands": [
                "workbench.action.closeEditorsInOtherGroups"
            ]
        },
        {
            "before": [
                "s",
                ","
            ],
            "commands": [
                "workbench.action.decreaseViewSize"
            ]
        },
        {
            "before": [
                "s",
                "."
            ],
            "commands": [
                "workbench.action.increaseViewSize"
            ]
        },
        {
            "before": [
                "s",
                "j"
            ],
            "commands": [
                "workbench.action.decreaseViewSize"
            ]
        },
        {
            "before": [
                "s",
                "k"
            ],
            "commands": [
                "workbench.action.increaseViewSize"
            ]
        },
        {
            "before": [
                "s",
                "="
            ],
            "commands": [
                "workbench.action.evenEditorWidths"
            ]
        },
        {
            "before": [
                "<leader>",
                "k"
            ],
            "commands": [
                "workbench.action.focusAboveGroup"
            ]
        },
        {
            "before": [
                "<leader>",
                "j"
            ],
            "commands": [
                "workbench.action.focusBelowGroup"
            ]
        },
        {
            "before": [
                "<leader>",
                "h"
            ],
            "commands": [
                "workbench.action.focusLeftGroup"
            ]
        },
        {
            "before": [
                "<leader>",
                "l"
            ],
            "commands": [
                "workbench.action.focusRightGroup"
            ]
        },
        {
            "before": [
                "<leader>",
                "d",
                "d"
            ],
            "commands": [
                "workbench.action.debug.start"
            ]
        },
        {
            "before": [
                "<leader>",
                "d",
                "c"
            ],
            "commands": [
                "workbench.action.debug.continue"
            ],
            "when": "debugState == 'stopped'"
        },
        {
            "before": [
                "<leader>",
                "d",
                "s"
            ],
            "commands": [
                "workbench.action.debug.stop"
            ],
            "when": "inDebugMode && !focusedSessionIsAttach"
        },
        {
            "before": [
                "<leader>",
                "d",
                "n"
            ],
            "commands": [
                "workbench.action.debug.stepOver"
            ],
            "when": "debugState == 'stopped'"
        },
        {
            "before": [
                "<leader>",
                "d",
                "i"
            ],
            "commands": [
                "workbench.action.debug.stepInto"
            ],
            "when": "debugState != 'inactive'"
        },
        {
            "before": [
                "<leader>",
                "d",
                "o"
            ],
            "commands": [
                "workbench.action.debug.stepOut"
            ],
            "when": "debugState == 'stopped'"
        },
        {
            "before": [
                "<leader>",
                "d",
                "b"
            ],
            "commands": [
                "editor.debug.action.toggleBreakpoint"
            ],
            "when": "debuggersAvailable && disassemblyViewFocus || debuggersAvailable && editorTextFocus"
        },
        {
            "before": [
                "<leader>",
                "g",
                "h"
            ],
            "commands": [
                "testing.showMostRecentOutput"
            ],
            "when": ""
        }
    ],
    "vim.visualModeKeyBindingsNonRecursive": [
        {
            "before": [
                "<leader>",
                "x"
            ],
            "commands": [
                "editor.action.refactor"
            ],
            "when": "editorHasCodeActionsProvider && editorTextFocus && !editorReadonly"
        },
        {
            "before": [
                "<leader>",
                "a",
                "h"
            ],
            "commands": [
                "cursorai.action.generateInTerminal"
            ]
        },
        {
            "before": [
                "<leader>",
                "a",
                "c"
            ],
            "commands": [
                "aichat.insertselectionintochat",
                "aichat.append 'Please explain this'",
                "aichat.submit"
            ]
        },
        {
            "before": [
                "<leader>",
                "a",
                "p"
            ],
            "commands": [
                "composer.sendToAgent"
            ]
        },
        {
            "before": [
                ">"
            ],
            "after": [
                ">",
                "g",
                "v"
            ]
        },
        {
            "before": [
                "p"
            ],
            "after": [
                "p",
                "g",
                "v",
                "y"
            ]
        }
    ],
    "vim.insertModeKeyBindingsNonRecursive": [
        {
            "before": [
                "<C-n>"
            ],
            "commands": [
                "editor.action.triggerSuggest"
            ],
            "when": "editorHasCompletionItemProvider && textInputFocus && !editorReadonly && !suggestWidgetVisible"
        },
        {
            "before": [
                "<C-j>"
            ],
            "commands": [
                "editor.action.inlineSuggest.trigger"
            ],
            "when": "config.github.copilot.inlineSuggest.enable && editorTextFocus && !editorHasSelection && !inlineSuggestionsVisible"
        }
    ],
    "vim.operatorPendingModeKeyBindingsNonRecursive": [
        {
            "before": [
                "L"
            ],
            "after": [
                "$"
            ]
        },
        {
            "before": [
                "H"
            ],
            "after": [
                "^"
            ]
        }
    ],
    "git.enableSmartCommit": true,
    "git.autofetch": true,
    "git.autoStash": true,
    "git.confirmSync": false,
    "diffEditor.ignoreTrimWhitespace": false,
    "cursor.general.disableHttp2": false,
    "update.mode": "none"
}
